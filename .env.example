# Guide — environment configuration
# Copy this file to .env and adjust values as needed.
# In mock mode, no external services are contacted.

# Core behaviour
GUIDE_MOCK_MODE=true
GUIDE_EVIDENCE_SINK=file        # file | none | webhook

# Optional external integrations (leave blank to disable)
GUIDE_LRS_ENDPOINT=
GUIDE_REDMINE_URL=
GUIDE_OPENPROJECT_URL=
GUIDE_NEXTCLOUD_URL=

# Evidence storage (used when GUIDE_EVIDENCE_SINK=file)
# Defaults to ~/.guide/events.jsonl when not set
GUIDE_EVIDENCE_PATH=
